# 后端服务端口
PORT=3000

# 资源硬盘白名单（json 数组），建议填入需要共享的目录（macOS：可用 /Users/你的用户名/xxx 或 /Volumes/磁盘名/xxx）
# 例：
#   DISK_LIST=[{"id":"disk1","name":"视频","path":"/Users/yourname/Videos"}]
#   DISK_LIST=[{"id":"disk1","name":"资源","path":"/Volumes/Macintosh HD/Users/yourname/Downloads"}]
DISK_LIST=[
  {"id":"disk1","name":"视频","path":"/Users/yourname/Videos"}
]

# 递归扫描深度（避免遍历整个磁盘）
MAX_SCAN_DEPTH=3

# 资源列表缓存时长（秒）
CACHE_TTL_SECONDS=300
